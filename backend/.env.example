# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/cmul8

# Cloudflare R2
CF_ACCOUNT_ID=89d4be72e5d4d2a4bdabe04957889355
CF_R2_ACCESS_KEY=your_access_key
CF_R2_SECRET_KEY=your_secret_key
R2_BUCKET=cmul8-assets
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# OpenAI (for embeddings)
OPENAI_API_KEY=sk-xxx

# Anthropic (for LLM)
ANTHROPIC_API_KEY=sk-ant-xxx

# BytePlus Seed (primary LLM for data analysis - OpenAI API compatible)
DOUBAO_API_KEY=your_byteplus_api_key
DOUBAO_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
DOUBAO_MODEL=seed-1-8-251228

# Moonshot Kimi (backup LLM - OpenAI API compatible)
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-128k

# Which LLM to use for data analysis: "claude", "doubao", "moonshot"
ANALYST_LLM=doubao

# App
ENV=development
